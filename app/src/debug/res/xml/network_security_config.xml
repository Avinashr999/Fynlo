<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY override of the main network security config. Identical to the
  release config, but additionally permits cleartext to the local Firebase
  emulator (10.0.2.2 = the host loopback as seen from an Android emulator, and
  localhost) so instrumented tests like FirestoreResetTest can talk to the
  Firestore emulator over plain HTTP/gRPC. This file only applies to debug
  builds — release keeps cleartext fully disabled.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
