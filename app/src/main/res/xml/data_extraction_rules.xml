<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup/transfer rules. The Room DB, PIN and DataStore prefs are
  excluded so a reinstall starts clean — signed-in users restore via Firestore,
  offline users via the in-app JSON export. See backup_rules.xml for the
  rationale (avoids stale data resurrecting on reinstall / undoing Reset All Data).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database"  path="Fynlo_database" />
        <exclude domain="database"  path="Fynlo_database-shm" />
        <exclude domain="database"  path="Fynlo_database-wal" />
        <exclude domain="sharedpref" path="Fynlo_pin.xml" />
        <exclude domain="file"       path="datastore" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database"  path="Fynlo_database" />
        <exclude domain="database"  path="Fynlo_database-shm" />
        <exclude domain="database"  path="Fynlo_database-wal" />
        <exclude domain="sharedpref" path="Fynlo_pin.xml" />
        <exclude domain="file"       path="datastore" />
    </device-transfer>
</data-extraction-rules>
